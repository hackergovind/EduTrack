# ─── Database (Neon.tech PostgreSQL - Free Tier) ─────────────────
# Sign up at https://neon.tech and create a project to get your connection string
DATABASE_URL="postgresql://username:password@your-neon-host.neon.tech/neondb?sslmode=require"

# ─── Authentication ──────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"

# The public URL of your deployed app
NEXTAUTH_URL="https://your-app.vercel.app"

# ─── Google OAuth ────────────────────────────────────────────────
# Get these from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── YouTube Data API ───────────────────────────────────────────
# Get this from https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY="your-youtube-api-key"
